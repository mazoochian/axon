#!/usr/bin/env bash
# Build a Mix release and start it in production mode.
#
# Required env vars:
#   AXON_SERVER_NAME   — e.g. matrix.example.com
#   SECRET_KEY_BASE    — 64+ random bytes (generate with: mix phx.gen.secret)
#
# Optional env vars (defaults shown):
#   DB_HOST=localhost  DB_NAME=axon_prod  DB_USER=axon  DB_PASS=axon
#   POOL_SIZE=20
#
# Usage:
#   AXON_SERVER_NAME=matrix.example.com SECRET_KEY_BASE=... ./bin/deploy
set -euo pipefail

cd "$(dirname "$0")/.."

: "${AXON_SERVER_NAME:?AXON_SERVER_NAME must be set}"
: "${SECRET_KEY_BASE:?SECRET_KEY_BASE must be set (run: mix phx.gen.secret)}"

export MIX_ENV=prod

echo "==> Installing dependencies (prod only)"
mix deps.get --only prod

echo "==> Compiling"
mix compile

echo "==> Building release"
mix release axon --overwrite

echo "==> Running migrations"
# Use the compiled release's eval to run migrations in prod env
_build/prod/rel/axon/bin/axon eval "AxonCore.Release.migrate()"

echo "==> Starting Axon"
exec _build/prod/rel/axon/bin/axon start
