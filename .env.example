# Copy to .env and fill in real values before running `docker compose up`.
# See README.md "Environment variables" for the full reference.

AXON_SERVER_NAME=matrix.example.com

DB_USER=axon
DB_PASS=changeme
DB_NAME=axon_prod
POOL_SIZE=20

# Generate with: openssl rand -hex 32
SECRET_KEY_BASE=

# Optional: delegated OIDC login
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_CLIENT_AUTH_METHOD=client_secret_basic
# OIDC_ACCOUNT_MANAGEMENT_URL=

# Optional: Sentry error tracking (added in Phase 15.3) — leave unset to no-op
# SENTRY_DSN=
